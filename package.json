{
  "name": "@sessionguard/cli",
  "version": "0.3.0",
  "description": "Security audit for local AI coding agent sessions (Claude Code, Cursor, Windsurf). Scans for leaked secrets, risky commands, and unsafe edits — all local, zero upload.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sessionguard/sessionguard.git"
  },
  "homepage": "https://github.com/sessionguard/sessionguard#readme",
  "bugs": {
    "url": "https://github.com/sessionguard/sessionguard/issues"
  },
  "bin": {
    "sessionguard": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "build:prod": "rm -rf dist && tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "test": "npm run build && node --test --experimental-test-coverage --test-reporter=spec $(find dist -name '*.test.js')",
    "check": "npm run typecheck && npm run lint && npm test",
    "prepare": "lefthook install 2>/dev/null || true",
    "prepublishOnly": "npm run check",
    "prepack": "npm run build:prod"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "claude-code",
    "cursor",
    "windsurf",
    "ai-coding",
    "security",
    "audit",
    "secrets-scan",
    "observability"
  ],
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@types/node": "^22.0.0",
    "lefthook": "2.1.6",
    "typescript": "^5.5.0"
  }
}
